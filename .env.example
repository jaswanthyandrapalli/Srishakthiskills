PORT=5000

# MongoDB Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sri-sakthi-sarees

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d

# Initial Super Admin Setup
SUPER_ADMIN_EMAIL=admin@srisakthi.com
SUPER_ADMIN_PASSWORD=AdminPassword123

# Frontend URL for CORS configuration (use the Vercel app URL for production)
FRONTEND_URL=http://localhost:3000

# Cloudinary Credentials (for product image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay Test Credentials (for payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SMTP Email Configuration (for sending registration OTPs)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Sri Sakthi Sarees <your_email@gmail.com>"
